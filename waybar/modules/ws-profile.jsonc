{
    "custom/ws-profile": {
        "exec": "~/.config/hypr/scripts/workspace_profile_status.sh",
        "return-type": "json",
        "interval": 5,
        "signal": 8,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "on-click": "~/.config/hypr/scripts/workspace_group.sh profile-next",
        "on-click-right": "~/.config/hypr/scripts/workspace_group.sh profile-prev"
    }
}
